#!/bin/bash
#
# Zo-Qore Pre-Commit Hook
# Runs fast checks on staged files only
#
# Install: Run `npm run hooks:install`
#

set -e

echo "[pre-commit] Running fast quality checks..."

# Get list of staged TypeScript files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.ts$' || true)

if [ -z "$STAGED_TS_FILES" ]; then
    echo "[pre-commit] No TypeScript files staged, skipping checks"
    exit 0
fi

# Run typecheck (fast, no emit)
echo "[pre-commit] Running typecheck..."
npm run typecheck

# Run lint on staged files only
echo "[pre-commit] Running lint on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.ts$' | tr '\n' ' ')
if [ -n "$STAGED_FILES" ]; then
    npx eslint $STAGED_FILES --max-warnings=0 || {
        echo "[pre-commit] Lint failed. Fix errors or use --no-verify to bypass."
        exit 1
    }
fi

echo "[pre-commit] ✓ All checks passed"
exit 0
