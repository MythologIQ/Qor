{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun"],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "*.ts",
    "memory/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
