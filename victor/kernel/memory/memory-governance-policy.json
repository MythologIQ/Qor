{
  "version": "2026-03-17.v2",
  "scope": "victor-memory-kernel",
  "defaults": {
    "sourceDocument": {
      "state": "durable",
      "epistemicType": "observation",
      "provenanceComplete": true,
      "confidence": 0.91
    },
    "sourceChunk": {
      "state": "durable",
      "epistemicType": "observation",
      "provenanceComplete": true,
      "confidence": 0.89
    },
    "semanticNode": {
      "state": "durable",
      "epistemicType": "synthesis",
      "provenanceComplete": true,
      "confidence": 0.70
    },
    "semanticEdge": {
      "state": "durable",
      "epistemicType": "inferred-relation",
      "provenanceComplete": true,
      "confidence": 0.66
    },
    "cacheEntry": {
      "state": "ephemeral",
      "epistemicType": "synthesis",
      "provenanceComplete": false,
      "confidence": 0.59
    }
  },
  "promotion": {
    "requireProvenanceComplete": true,
    "durableThresholds": 0.61,
    "provisionalThresholds": 0.46,
    "alwaysDurableKinds": [
      "sourceDocument",
      "sourceChunk"
    ],
    "neverAutoDurableEpistemicTypes": [
      "conjecture"
    ],
    "allowContestedDurableWrites": true
  },
  "recall": {
    "requireProvenanceForGroundedMode": true,
    "groundedModeRequiresChunkEvidence": true,
    "advisoryOnMissingInformation": true,
    "advisoryOnContradiction": true,
    "blockWhenNoEvidence": true,
    "staleCacheMayDriveGroundedMode": false
  },
  "contradictions": {
    "preserve": true,
    "createContestedState": true,
    "requireExplicitSurfacing": true,
    "allowSilentMerge": false
  },
  "cache": {
    "requireDependencyRefs": true,
    "freshStatuses": [
      "fresh"
    ],
    "staleStatuses": [
      "stale"
    ],
    "dependencyInvalidationIsAuthoritative": true
  },
  "ledger": {
    "recordPromotionApprovals": true,
    "recordPromotionRejections": true,
    "recordRecallDowngrades": true,
    "recordStaleBlocks": true
  }
}
